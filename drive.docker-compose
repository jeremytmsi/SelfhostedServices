services:
  drive:
    image: nextcloud
    container_name: nextcloud
    volumes:
      - /mnt/Data/Drive/Nextcloud:/var/www/html/data
      - nextcloud_config:/var/www/html/config
    environment:
      - PGID=1000
      - PUID=1000
    ports:
      - 8083:80
    networks:
      - front

volumes:
  nextcloud_config:

networks:
 front: